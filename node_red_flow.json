    {
        "id": "calc-consumo",
        "type": "function",
        "z": "f6f2187d.f17a88",
        "name": "Calcular Consumo Acumulado",
        "func": "// Inicializar consumos acumulados en el contexto del flujo si no existen\nlet diario = flow.get('consumoDiario') || 0;\nlet semanal = flow.get('consumoSemanal') || 0;\nlet ultimoTimestamp = flow.get('ultimoTimestamp') || Date.now();\n\nlet ahora = Date.now();\nlet deltaMs = ahora - ultimoTimestamp;\nflow.set('ultimoTimestamp', ahora);\n\n// Si el intervalo de tiempo es razonable (evitar saltos en reconexiones)\nif (deltaMs > 0 && deltaMs < 5000) {\n    let flow_l_min = msg.payload.flow_l_min || 0;\n    // Litros consumidos en este intervalo = caudal (L/min) * tiempo (minutos)\n    let litros = flow_l_min * (deltaMs / 60000.0);\n    \n    diario += litros;\n    semanal += litros;\n    \n    flow.set('consumoDiario', diario);\n    flow.set('consumoSemanal', semanal);\n}\n\n// Reinicio diario a las 00:00 (basado en fecha)\nlet hoy = new Date();\nlet ultimoDia = flow.get('ultimoDia') || hoy.getDate();\nif (hoy.getDate() !== ultimoDia) {\n    diario = 0;\n    flow.set('consumoDiario', diario);\n    flow.set('ultimoDia', hoy.getDate());\n    // Si es lunes, reiniciar también semanal\n    if (hoy.getDay() === 1) {\n        semanal = 0;\n        flow.set('consumoSemanal', semanal);\n    }\n}\n\nmsg.payload = {\n    flow_l_min: msg.payload.flow_l_min,\n    pulses: msg.payload.pulses,\n    consumoDiarioL: parseFloat(diario.toFixed(2)),\n    consumoSemanalL: parseFloat(semanal.toFixed(2))\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 360,
        "wires": [
            [
                "mqtt-out-consumo",
                "debug-consumo"
            ]
        ]
    },
