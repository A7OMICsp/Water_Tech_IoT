    {
        "id": "proc-alertas",
        "type": "function",
        "z": "f6f2187d.f17a88",
        "name": "Procesador de Alertas",
        "func": "let alerta = msg.payload;\nlet timestamp = new Date().toISOString();\n\nmsg.payload = {\n    alerta: alerta,\n    timestamp: timestamp,\n    mensaje: \"\"\n};\n\nif (alerta === \"Fuga_detectada_valvula_cerrada\") {\n    msg.payload.mensaje = \"⚠️ ALERTA CRÍTICA: Se detecta paso de agua con la válvula CERRADA!\";\n} else if (alerta === \"Fuga_Tiempo_Excesivo\") {\n    msg.payload.mensaje = \"🚨 ALERTA CRÍTICA: Flujo continuo de agua detectado por demasiado tiempo. El sistema ha cerrado los equipos por seguridad.\";\n} else {\n    msg.payload.mensaje = \"Alerta de agua: \" + alerta;\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
